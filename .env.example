# ─────────────────────────────────────────────────────────────
# VinTH — biến môi trường Supabase
# Sao chép file này thành `.env.local` rồi điền giá trị thật.
# Lấy các giá trị tại: Supabase Dashboard → Project Settings → API
# ─────────────────────────────────────────────────────────────

# URL project Supabase (vd: https://abcdxyz.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Khoá publishable / anon (an toàn để dùng phía trình duyệt — đã có RLS bảo vệ)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Khoá service_role — CHỈ dùng phía server (seed dữ liệu, tác vụ admin).
# TUYỆT ĐỐI không commit khoá này, không để lộ ra client.
SUPABASE_SERVICE_ROLE_KEY=

# Tên bucket Storage chứa ảnh/video căn hộ (mặc định: apartment-media)
NEXT_PUBLIC_SUPABASE_MEDIA_BUCKET=apartment-media
